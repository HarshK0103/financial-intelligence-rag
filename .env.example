#########################################
# Financial Intelligence Platform
# Docker Compose Environment
#########################################

###############################
# Application
###############################

APP_HOST=0.0.0.0
APP_PORT=8000
RAG_DEBUG=false

###############################
# Redis
###############################

# Docker Compose service name
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

###############################
# Connectors
###############################

CONNECTORS_ENABLED=true
CONNECTORS_STARTUP_SYNC=true
CONNECTOR_TIMEOUT_SECONDS=20

CONNECTOR_MARKET_SYMBOLS=AAPL,NVDA,TSLA,MSFT,GOOGL,AMZN,META,JPM,GS,BAC,BTC,ETH,SPY,QQQ

###############################
# SEC Connector
###############################

SEC_CONNECTOR_ENABLED=true
SEC_POLL_INTERVAL_SECONDS=1800

SEC_USER_AGENT=FinancialIntelligencePlatform/1.0 your-email@example.com

SEC_FORMS=10-K,10-Q,8-K

# Download full filing text
CONNECTORS_SEC_FULL_TEXT=false

SEC_CIK_MAP={"AAPL":"0000320193","MSFT":"0000789019","NVDA":"0001045810","AMZN":"0001018724","META":"0001326801","GOOGL":"0001652044","TSLA":"0001318605","JPM":"0000019617","GS":"0000886982","BAC":"0000070858"}

###############################
# Finnhub
###############################

# Disabled by default
FINNHUB_ENABLED=false

FINNHUB_API_KEY=your_finnhub_api_key

FINNHUB_BASE_URL=https://finnhub.io/api/v1

FINNHUB_POLL_INTERVAL_SECONDS=300

###############################
# Alpha Vantage
###############################

# Disabled by default
ALPHA_VANTAGE_ENABLED=false

ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

ALPHA_POLL_INTERVAL_SECONDS=300

###############################
# Inference
###############################

INFERENCE_BACKEND=ollama

INFERENCE_MAX_OUTPUT_TOKENS=300
INFERENCE_TEMPERATURE=0.1

INFERENCE_PROMPT_COMPRESSION=true
INFERENCE_TEMPLATE_MODE=true

###############################
# Ollama
###############################

OLLAMA_ENABLED=true

# Docker Compose service name
OLLAMA_BASE_URL=http://ollama:11434

OLLAMA_MODEL=llama3:latest

OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_KEEP_ALIVE=10m

###############################
# Monitoring
###############################

PROMETHEUS_ENABLED=true

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin